<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BattleshipMaui.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:BattleshipMaui.Behaviors"
    xmlns:controls="clr-namespace:BattleshipMaui.Controls"
    xmlns:vm="clr-namespace:BattleshipMaui.ViewModels"
    BackgroundColor="{DynamicResource GameColorBackground}"
    Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:BoardViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">
        <Border Grid.Row="0"
                IsVisible="{Binding ShowCompactCommandHeader}"
                Stroke="{DynamicResource GameColorBorder}"
                StrokeThickness="0,0,0,1"
                Padding="12,8">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,1">
                    <GradientStop Color="{DynamicResource GameColorHeaderStart}" Offset="0" />
                    <GradientStop Color="{DynamicResource GameColorHeaderEnd}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="1.1*,1.2*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="1">
                    <Label Text="{Binding CompactHeaderTitle}"
                           Style="{StaticResource GameSectionLabelStyle}"
                           FontSize="24"
                           TextColor="#E9F7FF" />
                    <Label Text="{Binding CompactHeaderStatus}"
                           Style="{StaticResource GameCaptionLabelStyle}"
                           FontSize="12"
                           LineBreakMode="TailTruncation"
                           TextColor="#9BC4E7" />
                </VerticalStackLayout>

                <Label Grid.Column="1"
                       Text="{Binding CurrentGameStatsLine}"
                       Style="{StaticResource GameCaptionLabelStyle}"
                       FontSize="13"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{DynamicResource GameColorAccent}" />

                <HorizontalStackLayout Grid.Column="2"
                                       Spacing="8"
                                       VerticalOptions="Center">
                    <Button Text="New Mission"
                            Command="{Binding NewGameCommand}"
                            Style="{StaticResource GamePrimaryButtonStyle}"
                            HeightRequest="38"
                            Padding="16,8" />
                    <Button Text="Reset Stats"
                            Command="{Binding ResetStatsCommand}"
                            Style="{StaticResource GameSecondaryButtonStyle}"
                            HeightRequest="38"
                            Padding="16,8" />
                    <Button Text="Disconnect"
                            Command="{Binding DisconnectLanCommand}"
                            IsVisible="{Binding IsLanConnected}"
                            Style="{StaticResource GameSecondaryButtonStyle}"
                            HeightRequest="38"
                            Padding="16,8" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                IsVisible="{Binding ShowExpandedCommandHeader}"
                Stroke="{DynamicResource GameColorBorder}"
                StrokeThickness="0,0,0,1"
                Padding="14,12">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,1">
                    <GradientStop Color="{DynamicResource GameColorHeaderStart}" Offset="0" />
                    <GradientStop Color="{DynamicResource GameColorHeaderEnd}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding AppHeaderTitle}"
                           Style="{StaticResource GameTitleLabelStyle}"
                           FontSize="28"
                           TextColor="#E9F7FF" />
                    <Label Text="{Binding AppHeaderSubtitle}"
                           Style="{StaticResource GameCaptionLabelStyle}"
                           FontSize="13"
                           TextColor="#9BC4E7" />
                </VerticalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Start">
                    <Button Text="New Mission"
                            Command="{Binding NewGameCommand}"
                            Style="{StaticResource GamePrimaryButtonStyle}"
                            HeightRequest="40"
                            Padding="16,9" />
                    <Button Text="Reset Stats"
                            Command="{Binding ResetStatsCommand}"
                            Style="{StaticResource GameSecondaryButtonStyle}"
                            HeightRequest="40"
                            Padding="16,9" />
                </HorizontalStackLayout>

                <Grid Grid.Row="1"
                      Grid.ColumnSpan="2"
                      ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                      ColumnSpacing="8">
                    <Button Text="Fire Control"
                            Command="{Binding SetBoardViewModeCommand}"
                            CommandParameter="Enemy"
                            Style="{StaticResource GameSecondaryButtonStyle}"
                            BackgroundColor="{Binding EnemyBoardTabBackground}"
                            WidthRequest="134"
                            HeightRequest="38"
                            Padding="14,8" />
                    <Button Grid.Column="1"
                            Text="Fleet Ops"
                            Command="{Binding SetBoardViewModeCommand}"
                            CommandParameter="Player"
                            Style="{StaticResource GameSecondaryButtonStyle}"
                            BackgroundColor="{Binding PlayerBoardTabBackground}"
                            WidthRequest="118"
                            HeightRequest="38"
                            Padding="14,8" />

                    <HorizontalStackLayout Grid.Column="2"
                                           Spacing="6"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Start">
                        <Button Text="Theme Shift"
                                Command="{Binding CycleThemeCommand}"
                                Style="{StaticResource GameSecondaryButtonStyle}"
                                HeightRequest="36"
                                Padding="12,7" />
                        <Label Text="Theme"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               VerticalTextAlignment="Center" />
                        <Picker WidthRequest="190"
                                HeightRequest="36"
                                MinimumHeightRequest="36"
                                VerticalOptions="Center"
                                ItemsSource="{Binding ThemeOptions}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                TextColor="{DynamicResource GameColorTextPrimary}"
                                BackgroundColor="{DynamicResource GameColorSurfaceAlt}"
                                SelectedItem="{Binding SelectedThemeOption}" />
                    </HorizontalStackLayout>

                    <Label Grid.Column="4"
                           Text="{Binding BoardFocusSummary}"
                           Style="{StaticResource GameCaptionLabelStyle}"
                           FontSize="13"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="End"
                           TextColor="{DynamicResource GameColorTextMuted}" />
                </Grid>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Stroke="{DynamicResource GameColorBorder}"
                        BackgroundColor="#20111E2E"
                        Padding="12,10">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8">
                        <Grid IsVisible="{Binding SupportsSoloEdition}"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Label Text="{Binding SessionPanelTitle}"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   VerticalTextAlignment="Center"
                                   TextColor="{DynamicResource GameColorTextMuted}" />
                            <Label Grid.Column="1"
                                   Text="{Binding SoloEditionSummary}"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   LineBreakMode="TailTruncation"
                                   VerticalTextAlignment="Center"
                                   HorizontalTextAlignment="End"
                                   TextColor="{DynamicResource GameColorAccent}" />
                        </Grid>

                        <Grid IsVisible="{Binding SupportsLanEdition}"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Label Text="{Binding SessionPanelTitle}"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   VerticalTextAlignment="Center"
                                   TextColor="{DynamicResource GameColorTextMuted}" />
                            <Label Grid.Column="1"
                                   Text="{Binding LanStatusLine}"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   LineBreakMode="TailTruncation"
                                   VerticalTextAlignment="Center"
                                   HorizontalTextAlignment="End"
                                   TextColor="{DynamicResource GameColorAccent}" />
                        </Grid>

                        <Grid Grid.Row="1"
                              IsVisible="{Binding SupportsLanEdition}"
                              ColumnDefinitions="Auto,2.2*,Auto,0.9*,Auto,Auto,Auto"
                              ColumnSpacing="8">
                            <Label Text="Host IP"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   VerticalTextAlignment="Center"
                                   TextColor="{DynamicResource GameColorTextMuted}" />
                            <Entry Grid.Column="1"
                                   Text="{Binding LanHostAddress}"
                                   Placeholder="192.168.1.50"
                                   ClearButtonVisibility="WhileEditing"
                                   HeightRequest="38"
                                   BackgroundColor="{DynamicResource GameColorSurfaceAlt}"
                                   TextColor="{DynamicResource GameColorTextPrimary}" />
                            <Label Grid.Column="2"
                                   Text="Port"
                                   Style="{StaticResource GameCaptionLabelStyle}"
                                   FontSize="12"
                                   VerticalTextAlignment="Center"
                                   TextColor="{DynamicResource GameColorTextMuted}" />
                            <Entry Grid.Column="3"
                                   Text="{Binding LanPortText}"
                                   Placeholder="47652"
                                   Keyboard="Numeric"
                                   MaxLength="5"
                                   HeightRequest="38"
                                   BackgroundColor="{DynamicResource GameColorSurfaceAlt}"
                                   TextColor="{DynamicResource GameColorTextPrimary}" />
                            <Button Grid.Column="4"
                                    Text="Host LAN"
                                    Command="{Binding HostLanCommand}"
                                    IsEnabled="{Binding CanHostLan}"
                                    Style="{StaticResource GamePrimaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7" />
                            <Button Grid.Column="5"
                                    Text="Join LAN"
                                    Command="{Binding JoinLanCommand}"
                                    IsEnabled="{Binding CanJoinLan}"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7" />
                            <Button Grid.Column="6"
                                    Text="Disconnect"
                                    Command="{Binding DisconnectLanCommand}"
                                    IsEnabled="{Binding CanDisconnectLan}"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7" />
                        </Grid>

                        <Label Grid.Row="2"
                               IsVisible="{Binding SupportsLanEdition}"
                               Text="{Binding LanConnectionHelpText}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="{DynamicResource GameColorTextMuted}" />

                        <Label Grid.Row="2"
                               IsVisible="{Binding SupportsSoloEdition}"
                               Text="{Binding SoloEditionHelpText}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="{DynamicResource GameColorTextMuted}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid Padding="{Binding GameplayContentPadding}"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="8">
                    <Border Grid.Row="0"
                    IsVisible="{Binding ShowDetailedBattleStatusCard}"
                    Style="{StaticResource GameCardBorderStyle}"
                    Padding="12,8">
                <Grid ColumnDefinitions="1.3*,1.3*,1.4*" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding TurnMessage}"
                               Style="{StaticResource GameSectionLabelStyle}"
                               FontSize="26"
                               TextColor="{DynamicResource GameColorAccent}" />
                        <Label Text="{Binding StatusMessage}"
                               Style="{StaticResource GameBodyLabelStyle}"
                               FontSize="15"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Battle Status"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               TextColor="{DynamicResource GameColorTextMuted}" />
                        <Label Text="{Binding ScoreLine}"
                               Style="{StaticResource GameBodyLabelStyle}"
                               FontSize="15" />
                        <Label Text="{Binding CurrentGameStatsLine}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="13"
                               TextColor="{DynamicResource GameColorAccent}" />
                    </VerticalStackLayout>

                    <Grid Grid.Column="2" RowDefinitions="Auto,Auto" ColumnDefinitions="*" RowSpacing="4">
                        <Label Text="{Binding PlayerLastShotMessage}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               TextColor="{DynamicResource GameColorAccent}" />
                        <Label Grid.Row="1"
                               Text="{Binding EnemyLastShotMessage}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               TextColor="{DynamicResource GameColorWarning}" />
                    </Grid>
                </Grid>
            </Border>

                    <Border Grid.Row="1"
                    IsVisible="{Binding IsPlacementPhase}"
                    Style="{StaticResource GameCardBorderStyle}"
                    BackgroundColor="#0F2A45"
                    Padding="10,8">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Fleet Deployment"
                                   Style="{StaticResource GameSectionLabelStyle}"
                                   FontSize="18"
                                   TextColor="{DynamicResource GameColorWarning}" />
                            <Label Text="{Binding PlacementSelectionMessage}"
                                   Style="{StaticResource GameBodyLabelStyle}"
                                   FontSize="14"
                                   TextColor="{DynamicResource GameColorWarning}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="{Binding PlacementOrientationText}"
                                Command="{Binding RotatePlacementCommand}"
                                IsEnabled="{Binding CanRotatePlacement}"
                                Style="{StaticResource GameSecondaryButtonStyle}"
                                HeightRequest="36"
                                Padding="12,7"
                                SemanticProperties.Description="Rotate selected ship"
                                SemanticProperties.Hint="Switches between horizontal and vertical placement." />
                    </Grid>

                    <CollectionView ItemsSource="{Binding PlacementShips}"
                                    SelectionMode="None"
                                    HeightRequest="80"
                                    VerticalScrollBarVisibility="Never"
                                    HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{Binding CardBackground}"
                                        Stroke="{Binding CardStroke}"
                                        StrokeThickness="1.2"
                                        StrokeShape="{DynamicResource GameShipCardShape}"
                                        Padding="8,6"
                                        WidthRequest="142"
                                        HeightRequest="74">
                                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
                                        <Label Text="{Binding DisplayName}"
                                               Style="{StaticResource GameCaptionLabelStyle}"
                                               FontSize="12"
                                               TextColor="White"
                                               LineBreakMode="TailTruncation" />
                                        <Image Grid.Row="1"
                                               Source="{Binding ImageSource}"
                                               HeightRequest="30"
                                               Aspect="AspectFit" />

                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=SelectPlacementShipCommand}"
                                                CommandParameter="{Binding .}" />
                                            <TapGestureRecognizer
                                                Buttons="Secondary"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=RotatePlacementCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

                    <Grid x:Name="CommandCenterBoardHost"
                  Grid.Row="2"
                  ColumnDefinitions="Auto,Auto"
                  ColumnSpacing="18"
                  HorizontalOptions="Center"
                  VerticalOptions="FillAndExpand">
                <VerticalStackLayout x:Name="EnemyBoardPage"
                                     Grid.Column="0"
                                     Spacing="6"
                                     HorizontalOptions="Center"
                                     VerticalOptions="FillAndExpand">
                    <Label Text="Enemy Waters"
                           Style="{StaticResource GameSectionLabelStyle}"
                           FontSize="{Binding BoardTitleFontSize}"
                           Margin="0,2,0,0" />

                    <Border Style="{StaticResource GameCardBorderStyle}"
                            Padding="3"
                            HorizontalOptions="Center"
                            WidthRequest="{Binding BoardFramePixelSize}">
                        <Grid RowSpacing="{Binding BoardRailSpacingPixelSize}"
                              ColumnSpacing="{Binding BoardRailSpacingPixelSize}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{Binding AxisRailPixelSize}" />
                                <RowDefinition Height="{Binding BoardPixelSize}" />
                                <RowDefinition Height="{Binding AxisRailPixelSize}" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding AxisRailPixelSize}" />
                                <ColumnDefinition Width="{Binding BoardPixelSize}" />
                                <ColumnDefinition Width="{Binding AxisRailPixelSize}" />
                            </Grid.ColumnDefinitions>
                            <HorizontalStackLayout Grid.Row="0"
                                                   Grid.Column="1"
                                                   BindableLayout.ItemsSource="{Binding ColumnLabels}"
                                                   Spacing="0"
                                                   InputTransparent="True"
                                                   HorizontalOptions="Start"
                                                    HeightRequest="{Binding AxisRailPixelSize}"
                                                    WidthRequest="{Binding BoardPixelSize}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                               WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                               HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=AxisRailPixelSize}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{DynamicResource GameColorTextMuted}"
                                               FontSize="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=BoardAxisFontSize}"
                                               FontAttributes="Bold" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="0"
                                                 BindableLayout.ItemsSource="{Binding RowLabels}"
                                                 Spacing="0"
                                                 InputTransparent="True"
                                                 WidthRequest="{Binding AxisRailPixelSize}"
                                                 HeightRequest="{Binding BoardPixelSize}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                               WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=AxisRailPixelSize}"
                                               HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{DynamicResource GameColorTextMuted}"
                                               FontSize="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=BoardAxisFontSize}"
                                               FontAttributes="Bold" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  WidthRequest="{Binding BoardPixelSize}"
                                  HeightRequest="{Binding BoardPixelSize}"
                                  HorizontalOptions="Start"
                                  VerticalOptions="Start"
                                  IsClippedToBounds="False">
                                <Grid ZIndex="0">
                                    <Grid.Behaviors>
                                        <behaviors:BoardWaterFlowAnimationBehavior />
                                    </Grid.Behaviors>
                                    <Border Stroke="{DynamicResource GameColorBorder}"
                                            StrokeThickness="1.1"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="1,1">
                                                <GradientStop Color="{DynamicResource GameColorPanel}" Offset="0" />
                                                <GradientStop Color="{DynamicResource GameColorSurfaceAlt}" Offset="0.52" />
                                                <GradientStop Color="{DynamicResource GameColorSurface}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="#70000000" Radius="14" Opacity="0.55" Offset="0,4" />
                                        </Border.Shadow>
                                    </Border>
                                    <Border Margin="3"
                                            Stroke="{DynamicResource GameColorAccentSoft}"
                                            StrokeThickness="0.7"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            BackgroundColor="#0E3D6688" />
                                    <Border Margin="4"
                                            Stroke="#35FFFFFF"
                                            StrokeThickness="0.65"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            BackgroundColor="#061C2C3A"
                                            InputTransparent="True" />
                                    <Border ClassId="BoardWaveLayerA"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.58">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.12" EndPoint="1,0.88">
                                                <GradientStop Color="#00FFFFFF" Offset="0.0" />
                                                <GradientStop Color="#30C8F6FF" Offset="0.2" />
                                                <GradientStop Color="#0D6FB2D3" Offset="0.44" />
                                                <GradientStop Color="#2AB6ECFF" Offset="0.66" />
                                                <GradientStop Color="#00102736" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border ClassId="BoardWaveLayerB"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.42">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.95,0.08" EndPoint="0.12,0.95">
                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                <GradientStop Color="#2A79D3EA" Offset="0.3" />
                                                <GradientStop Color="#082F8DB0" Offset="0.54" />
                                                <GradientStop Color="#2696E4F6" Offset="0.74" />
                                                <GradientStop Color="#00000000" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border ClassId="BoardDepthVignette"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.62">
                                        <Border.Background>
                                            <RadialGradientBrush Center="0.5,0.5" Radius="0.92">
                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                <GradientStop Color="#0F000000" Offset="0.72" />
                                                <GradientStop Color="#32000000" Offset="1.0" />
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <controls:OceanBoardSurfaceView
                                    WidthRequest="{Binding BoardPixelSize}"
                                    HeightRequest="{Binding BoardPixelSize}"
                                    ItemsSource="{Binding EnemyCells}"
                                    ZIndex="1" />
                                <AbsoluteLayout InputTransparent="True"
                                                WidthRequest="{Binding BoardPixelSize}"
                                                HeightRequest="{Binding BoardPixelSize}"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                IsClippedToBounds="False"
                                                BindableLayout.ItemsSource="{Binding EnemyShipSprites}"
                                                IsVisible="{Binding ShowEnemyFleet}"
                                                ZIndex="3">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                                  AbsoluteLayout.LayoutFlags="None"
                                                  Rotation="{Binding Rotation}"
                                                  Opacity="{Binding Opacity}"
                                                  IsClippedToBounds="False">
                                                <Grid.Behaviors>
                                                    <behaviors:ShipSpriteAnimationBehavior />
                                                </Grid.Behaviors>

                                                <Border Stroke="{Binding StrokeColor}"
                                                        StrokeThickness="1.25"
                                                        StrokeShape="{DynamicResource GameShipSpriteShape}"
                                                        Padding="0"
                                                        BackgroundColor="{Binding BackgroundColor}" />

                                                <Image Source="{Binding ImageSource}"
                                                       Rotation="{Binding ImageRotation}"
                                                       WidthRequest="{Binding ImageWidthRequest}"
                                                       HeightRequest="{Binding ImageHeightRequest}"
                                                       TranslationX="{Binding ImageTranslationX}"
                                                       TranslationY="{Binding ImageTranslationY}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       Aspect="AspectFit"
                                                       InputTransparent="True" />

                                                <Grid IsVisible="{Binding IsSunkSmokeVisible}"
                                                      InputTransparent="True">
                                                    <Grid.Behaviors>
                                                        <behaviors:ShipSunkSmokeAnimationBehavior />
                                                    </Grid.Behaviors>
                                                    <Border Margin="-2"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10"
                                                            Opacity="0.34">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.68" Radius="0.92">
                                                                <GradientStop Color="#8EE2E8EE" Offset="0.0" />
                                                                <GradientStop Color="#78AAB5C4" Offset="0.38" />
                                                                <GradientStop Color="#485A6573" Offset="0.72" />
                                                                <GradientStop Color="#0039424E" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                    <Border Margin="2"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10"
                                                            Opacity="0.58">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.62" Radius="0.72">
                                                                <GradientStop Color="#9AD5DCE4" Offset="0.0" />
                                                                <GradientStop Color="#7D909AA8" Offset="0.34" />
                                                                <GradientStop Color="#4A5C6673" Offset="0.7" />
                                                                <GradientStop Color="#00434A56" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                    <Border Margin="6"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 8"
                                                            Opacity="0.38">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.48,0.48" Radius="0.58">
                                                                <GradientStop Color="#88E3E8EE" Offset="0.0" />
                                                                <GradientStop Color="#438A909A" Offset="0.7" />
                                                                <GradientStop Color="#00707580" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>

                                <Grid x:Name="EnemyBoardCellsHost"
                                      BindableLayout.ItemsSource="{Binding EnemyCells}"
                                      IsEnabled="{Binding CanFire}"
                                      WidthRequest="{Binding BoardPixelSize}"
                                      HeightRequest="{Binding BoardPixelSize}"
                                      Margin="0"
                                      RowSpacing="0"
                                      ColumnSpacing="0"
                                      ZIndex="2"
                                      SemanticProperties.Description="Enemy waters grid."
                                      SemanticProperties.Hint="Rows are A to J and columns are 1 to 10. Tap a cell to fire.">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border Grid.Row="{Binding Row}"
                                                    Grid.Column="{Binding Col}"
                                                    Stroke="{Binding CellStrokeColor}"
                                                    StrokeThickness="0.9"
                                                    StrokeShape="{DynamicResource GameBoardCellShape}"
                                                    BackgroundColor="#01000000"
                                                    WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                                    HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                                    SemanticProperties.Description="{Binding AccessibilityText}"
                                                    SemanticProperties.Hint="Enemy cell. Tap to fire.">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=EnemyCellTappedCommand}"
                                                        CommandParameter="{Binding .}" />
                                                    <PointerGestureRecognizer PointerEntered="OnEnemyCellPointerEntered"
                                                                              PointerExited="OnEnemyBoardPointerExited" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </Grid>
                                <controls:BoardEffectsView
                                    WidthRequest="{Binding BoardPixelSize}"
                                    HeightRequest="{Binding BoardPixelSize}"
                                    ItemsSource="{Binding EnemyCells}"
                                    ZIndex="5" />
                            </Grid>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="PlayerBoardPage"
                                     Grid.Column="1"
                                     Spacing="6"
                                     HorizontalOptions="Center"
                                     VerticalOptions="FillAndExpand">
                    <Label Text="Your Fleet"
                           Style="{StaticResource GameSectionLabelStyle}"
                           FontSize="{Binding BoardTitleFontSize}"
                           Margin="0,2,0,0" />

                    <Border Style="{StaticResource GameCardBorderStyle}"
                            Padding="3"
                            HorizontalOptions="Center"
                            WidthRequest="{Binding BoardFramePixelSize}">
                        <Grid RowSpacing="{Binding BoardRailSpacingPixelSize}"
                              ColumnSpacing="{Binding BoardRailSpacingPixelSize}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{Binding AxisRailPixelSize}" />
                                <RowDefinition Height="{Binding BoardPixelSize}" />
                                <RowDefinition Height="{Binding AxisRailPixelSize}" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding AxisRailPixelSize}" />
                                <ColumnDefinition Width="{Binding BoardPixelSize}" />
                                <ColumnDefinition Width="{Binding AxisRailPixelSize}" />
                            </Grid.ColumnDefinitions>
                            <HorizontalStackLayout Grid.Row="0"
                                                   Grid.Column="1"
                                                   BindableLayout.ItemsSource="{Binding ColumnLabels}"
                                                   Spacing="0"
                                                   InputTransparent="True"
                                                   HorizontalOptions="Start"
                                                    HeightRequest="{Binding AxisRailPixelSize}"
                                                    WidthRequest="{Binding BoardPixelSize}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                               WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                               HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=AxisRailPixelSize}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{DynamicResource GameColorTextMuted}"
                                               FontSize="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=BoardAxisFontSize}"
                                               FontAttributes="Bold" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="0"
                                                 BindableLayout.ItemsSource="{Binding RowLabels}"
                                                 Spacing="0"
                                                 InputTransparent="True"
                                                 WidthRequest="{Binding AxisRailPixelSize}"
                                                 HeightRequest="{Binding BoardPixelSize}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                               WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=AxisRailPixelSize}"
                                               HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{DynamicResource GameColorTextMuted}"
                                               FontSize="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=BoardAxisFontSize}"
                                               FontAttributes="Bold" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  WidthRequest="{Binding BoardPixelSize}"
                                  HeightRequest="{Binding BoardPixelSize}"
                                  HorizontalOptions="Start"
                                  VerticalOptions="Start"
                                  IsClippedToBounds="False">
                                <Grid ZIndex="0">
                                    <Grid.Behaviors>
                                        <behaviors:BoardWaterFlowAnimationBehavior />
                                    </Grid.Behaviors>
                                    <Border Stroke="{DynamicResource GameColorBorder}"
                                            StrokeThickness="1.1"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="1,1">
                                                <GradientStop Color="{DynamicResource GameColorPanel}" Offset="0" />
                                                <GradientStop Color="{DynamicResource GameColorSurfaceAlt}" Offset="0.52" />
                                                <GradientStop Color="{DynamicResource GameColorSurface}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="#70000000" Radius="14" Opacity="0.55" Offset="0,4" />
                                        </Border.Shadow>
                                    </Border>
                                    <Border Margin="3"
                                            Stroke="{DynamicResource GameColorAccentSoft}"
                                            StrokeThickness="0.7"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            BackgroundColor="#0E3D6688" />
                                    <Border Margin="4"
                                            Stroke="#35FFFFFF"
                                            StrokeThickness="0.65"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            BackgroundColor="#061C2C3A"
                                            InputTransparent="True" />
                                    <Border ClassId="BoardWaveLayerA"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.58">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.12" EndPoint="1,0.88">
                                                <GradientStop Color="#00FFFFFF" Offset="0.0" />
                                                <GradientStop Color="#30C8F6FF" Offset="0.2" />
                                                <GradientStop Color="#0D6FB2D3" Offset="0.44" />
                                                <GradientStop Color="#2AB6ECFF" Offset="0.66" />
                                                <GradientStop Color="#00102736" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border ClassId="BoardWaveLayerB"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.42">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0.95,0.08" EndPoint="0.12,0.95">
                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                <GradientStop Color="#2A79D3EA" Offset="0.3" />
                                                <GradientStop Color="#082F8DB0" Offset="0.54" />
                                                <GradientStop Color="#2696E4F6" Offset="0.74" />
                                                <GradientStop Color="#00000000" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border ClassId="BoardDepthVignette"
                                            Margin="5"
                                            StrokeThickness="0"
                                            StrokeShape="{DynamicResource GameBoardFrameShape}"
                                            InputTransparent="True"
                                            Opacity="0.62">
                                        <Border.Background>
                                            <RadialGradientBrush Center="0.5,0.5" Radius="0.92">
                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                <GradientStop Color="#0F000000" Offset="0.72" />
                                                <GradientStop Color="#32000000" Offset="1.0" />
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <controls:OceanBoardSurfaceView
                                    WidthRequest="{Binding BoardPixelSize}"
                                    HeightRequest="{Binding BoardPixelSize}"
                                    ItemsSource="{Binding PlayerCells}"
                                    IsPlayerBoard="True"
                                    ZIndex="1" />
                                <AbsoluteLayout InputTransparent="True"
                                                WidthRequest="{Binding BoardPixelSize}"
                                                HeightRequest="{Binding BoardPixelSize}"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                IsClippedToBounds="False"
                                                BindableLayout.ItemsSource="{Binding PlayerShipSprites}"
                                                ZIndex="3">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid AbsoluteLayout.LayoutBounds="{Binding Bounds}"
                                                  AbsoluteLayout.LayoutFlags="None"
                                                  Rotation="{Binding Rotation}"
                                                  Opacity="{Binding Opacity}"
                                                  IsClippedToBounds="False">
                                                <Grid.Behaviors>
                                                    <behaviors:ShipSpriteAnimationBehavior />
                                                </Grid.Behaviors>

                                                <Border Stroke="{Binding StrokeColor}"
                                                        StrokeThickness="1.25"
                                                        StrokeShape="{DynamicResource GameShipSpriteShape}"
                                                        Padding="0"
                                                        BackgroundColor="{Binding BackgroundColor}" />

                                                <Image Source="{Binding ImageSource}"
                                                       Rotation="{Binding ImageRotation}"
                                                       WidthRequest="{Binding ImageWidthRequest}"
                                                       HeightRequest="{Binding ImageHeightRequest}"
                                                       TranslationX="{Binding ImageTranslationX}"
                                                       TranslationY="{Binding ImageTranslationY}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       Aspect="AspectFit"
                                                       InputTransparent="True" />

                                                <Grid IsVisible="{Binding IsSunkSmokeVisible}"
                                                      InputTransparent="True">
                                                    <Grid.Behaviors>
                                                        <behaviors:ShipSunkSmokeAnimationBehavior />
                                                    </Grid.Behaviors>
                                                    <Border Margin="-2"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10"
                                                            Opacity="0.34">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.68" Radius="0.92">
                                                                <GradientStop Color="#8EE2E8EE" Offset="0.0" />
                                                                <GradientStop Color="#78AAB5C4" Offset="0.38" />
                                                                <GradientStop Color="#485A6573" Offset="0.72" />
                                                                <GradientStop Color="#0039424E" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                    <Border Margin="2"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10"
                                                            Opacity="0.58">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.62" Radius="0.72">
                                                                <GradientStop Color="#9AD5DCE4" Offset="0.0" />
                                                                <GradientStop Color="#7D909AA8" Offset="0.34" />
                                                                <GradientStop Color="#4A5C6673" Offset="0.7" />
                                                                <GradientStop Color="#00434A56" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>

                                                    <Border Margin="6"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 8"
                                                            Opacity="0.38">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.48,0.48" Radius="0.58">
                                                                <GradientStop Color="#88E3E8EE" Offset="0.0" />
                                                                <GradientStop Color="#438A909A" Offset="0.7" />
                                                                <GradientStop Color="#00707580" Offset="1.0" />
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>

                                <AbsoluteLayout InputTransparent="True"
                                                WidthRequest="{Binding BoardPixelSize}"
                                                HeightRequest="{Binding BoardPixelSize}"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                IsClippedToBounds="False"
                                                IsVisible="{Binding IsPlacementPreviewVisible}"
                                                ZIndex="4">
                                    <Grid AbsoluteLayout.LayoutBounds="{Binding PlacementPreviewBounds}"
                                          AbsoluteLayout.LayoutFlags="None"
                                          IsClippedToBounds="False">
                                        <Border Stroke="{Binding PlacementPreviewStrokeColor}"
                                                StrokeThickness="1.6"
                                                StrokeShape="{DynamicResource GameShipSpriteShape}"
                                                BackgroundColor="{Binding PlacementPreviewFillColor}"
                                                Padding="0" />
                                        <Image Source="{Binding PlacementPreviewImageSource}"
                                               Rotation="{Binding PlacementPreviewImageRotation}"
                                               WidthRequest="{Binding PlacementPreviewImageWidthRequest}"
                                               HeightRequest="{Binding PlacementPreviewImageHeightRequest}"
                                               TranslationX="{Binding PlacementPreviewImageTranslationX}"
                                               TranslationY="{Binding PlacementPreviewImageTranslationY}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Aspect="AspectFit"
                                               Opacity="0.7"
                                               InputTransparent="True" />
                                    </Grid>
                                </AbsoluteLayout>

                                <Grid x:Name="PlayerBoardCellsHost"
                                      BindableLayout.ItemsSource="{Binding PlayerCells}"
                                      IsEnabled="{Binding CanPlaceShips}"
                                      WidthRequest="{Binding BoardPixelSize}"
                                      HeightRequest="{Binding BoardPixelSize}"
                                      Margin="0"
                                      RowSpacing="0"
                                      ColumnSpacing="0"
                                      ZIndex="2"
                                      SemanticProperties.Description="Your fleet grid."
                                      SemanticProperties.Hint="Rows are A to J and columns are 1 to 10. During placement, left-click a cell to place the selected ship and right-click to rotate.">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border Grid.Row="{Binding Row}"
                                                    Grid.Column="{Binding Col}"
                                                    Stroke="{Binding CellStrokeColor}"
                                                    StrokeThickness="0.9"
                                                    StrokeShape="{DynamicResource GameBoardCellShape}"
                                                    BackgroundColor="#01000000"
                                                    WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                                    HeightRequest="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=CellPixelSize}"
                                                    SemanticProperties.Description="{Binding AccessibilityText}"
                                                    SemanticProperties.Hint="Your fleet cell. Left-click to place the selected ship. Right-click to rotate orientation.">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=PlayerCellTappedCommand}"
                                                        CommandParameter="{Binding .}" />
                                                    <TapGestureRecognizer
                                                        Buttons="Secondary"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BoardViewModel}}, Path=RotatePlacementCommand}" />
                                                    <PointerGestureRecognizer PointerEntered="OnPlayerCellPointerEntered"
                                                                              PointerExited="OnPlayerBoardPointerExited" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </Grid>

                                <controls:BoardEffectsView
                                    WidthRequest="{Binding BoardPixelSize}"
                                    HeightRequest="{Binding BoardPixelSize}"
                                    ItemsSource="{Binding PlayerCells}"
                                    ZIndex="5" />
                            </Grid>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
                    </Grid>
                </Grid>

            <Grid x:Name="TurnTransitionScrim"
                  IsVisible="{Binding IsTurnTransitionActive}"
                  BackgroundColor="#66071221"
                  ZIndex="24"
                  InputTransparent="False">
                <Grid WidthRequest="760"
                      MaximumWidthRequest="760"
                      HorizontalOptions="Center"
                      VerticalOptions="Center"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="18">
                    <Grid HeightRequest="320"
                          WidthRequest="320"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">
                        <Border x:Name="TurnTransitionHalo"
                                WidthRequest="320"
                                HeightRequest="320"
                                StrokeThickness="0"
                                BackgroundColor="#05121f30"
                                StrokeShape="RoundRectangle 180" />

                        <Border x:Name="TurnTransitionPulseRing"
                                WidthRequest="284"
                                HeightRequest="284"
                                Stroke="{Binding TurnTransitionSpinnerColor}"
                                StrokeThickness="2.2"
                                StrokeShape="RoundRectangle 160"
                                BackgroundColor="#03101820"
                                Opacity="0.28"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                        <Grid x:Name="TurnTransitionSweepHost"
                              WidthRequest="304"
                              HeightRequest="304"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              InputTransparent="True">
                            <BoxView x:Name="TurnTransitionSweep"
                                     WidthRequest="142"
                                     HeightRequest="3"
                                     CornerRadius="2"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center"
                                     Color="{Binding TurnTransitionSpinnerColor}"
                                     Opacity="0.65" />
                        </Grid>

                        <Border x:Name="TurnTransitionReticle"
                                WidthRequest="248"
                                HeightRequest="248"
                                Stroke="{Binding TurnTransitionSpinnerColor}"
                                StrokeThickness="3"
                                StrokeShape="RoundRectangle 140"
                                BackgroundColor="#050d1826"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                        <Border x:Name="TurnTransitionInnerReticle"
                                WidthRequest="188"
                                HeightRequest="188"
                                Stroke="#40FFFFFF"
                                StrokeThickness="1.4"
                                StrokeShape="RoundRectangle 120"
                                BackgroundColor="#02131f2d"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                        <BoxView WidthRequest="260"
                                 HeightRequest="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Color="{Binding TurnTransitionSpinnerColor}"
                                 Opacity="0.78" />

                        <BoxView WidthRequest="2"
                                 HeightRequest="260"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Color="{Binding TurnTransitionSpinnerColor}"
                                 Opacity="0.78" />

                        <Border x:Name="TurnTransitionCoordinateChip"
                                WidthRequest="172"
                                HeightRequest="132"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Stroke="{Binding TurnTransitionSpinnerColor}"
                                StrokeThickness="1.6"
                                StrokeShape="RoundRectangle 26"
                                BackgroundColor="#C30C1624"
                                Padding="12,10">
                            <VerticalStackLayout Spacing="0"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="TARGET"
                                       Style="{StaticResource GameCaptionLabelStyle}"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource GameColorTextMuted}" />
                                <Label Text="{Binding TurnTransitionCoordinate}"
                                       Style="{StaticResource GameSectionLabelStyle}"
                                       FontSize="54"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{Binding TurnTransitionSpinnerColor}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border x:Name="TurnTransitionCard"
                            Grid.Row="1"
                            Style="{StaticResource GameCardBorderStyle}"
                            HorizontalOptions="Center"
                            BackgroundColor="{DynamicResource GameColorTransitionCard}"
                            Padding="18,16">
                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="4"
                                                   HorizontalOptions="Center">
                                <Label Text="{Binding TurnTransitionTitle}"
                                       Style="{StaticResource GameSectionLabelStyle}"
                                       FontSize="23"
                                       VerticalTextAlignment="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource GameColorAccent}" />
                                <Label Text="{Binding ThinkingDots}"
                                       IsVisible="{Binding IsThinkingPromptActive}"
                                       Style="{StaticResource GameSectionLabelStyle}"
                                       FontSize="23"
                                       VerticalTextAlignment="Center"
                                       TextColor="{Binding TurnTransitionSpinnerColor}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding TurnTransitionMessage}"
                                   Style="{StaticResource GameBodyLabelStyle}"
                                   FontSize="16"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{DynamicResource GameColorTextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="IntelBubbleScrim"
                  IsVisible="{Binding IsIntelBubbleVisible}"
                  ZIndex="25"
                  InputTransparent="True">
                <Border x:Name="IntelBubbleCard"
                        Style="{StaticResource GameCardBorderStyle}"
                        HorizontalOptions="Center"
                        VerticalOptions="Start"
                        Margin="0,18,0,0"
                        Padding="14,10"
                        BackgroundColor="#D40E1826"
                        Stroke="{DynamicResource GameColorAccent}">
                    <VerticalStackLayout Spacing="2"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding IntelBubbleTitle}"
                               Style="{StaticResource GameCaptionLabelStyle}"
                               FontSize="12"
                               HorizontalTextAlignment="Center"
                               TextColor="{DynamicResource GameColorWarning}" />
                        <Label Text="{Binding IntelBubbleMessage}"
                               Style="{StaticResource GameBodyLabelStyle}"
                               FontSize="15"
                               HorizontalTextAlignment="Center"
                               TextColor="{DynamicResource GameColorTextPrimary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid x:Name="StartupSequenceScrim"
                  IsVisible="False"
                  BackgroundColor="#01050A"
                  ZIndex="28"
                  InputTransparent="False">
                <Grid>
                    <BoxView Color="#020913" />
                    <Border Margin="0"
                            StrokeThickness="0"
                            BackgroundColor="#FF051323">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0.42"
                                                 Radius="0.95">
                                <GradientStop Color="#FF0C233B" Offset="0.0" />
                                <GradientStop Color="#FF06182B" Offset="0.45" />
                                <GradientStop Color="#FF02070F" Offset="1.0" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid RowDefinitions="Auto,*,Auto"
                          Padding="42,32">
                        <HorizontalStackLayout Spacing="14"
                                               Opacity="0.16"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Start">
                            <BoxView WidthRequest="160"
                                     HeightRequest="2"
                                     Color="#3CD7FF" />
                            <BoxView WidthRequest="120"
                                     HeightRequest="2"
                                     Color="#1F88B4" />
                            <BoxView WidthRequest="220"
                                     HeightRequest="2"
                                     Color="#3CD7FF" />
                        </HorizontalStackLayout>

                        <Grid Grid.Row="1">
                            <Grid x:Name="StartupCreatorScene"
                                  Opacity="0"
                                  IsVisible="True">
                                <VerticalStackLayout Spacing="10"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label x:Name="StartupCreatorPrefixLabel"
                                           Text=""
                                           FontFamily="Impact"
                                           FontSize="32"
                                           CharacterSpacing="3"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#7FDFFF" />
                                    <Label x:Name="StartupCreatorNameLabel"
                                           Text=""
                                           FontFamily="Impact"
                                           FontSize="74"
                                           CharacterSpacing="1.5"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#DDF9FF">
                                        <Label.Shadow>
                                            <Shadow Brush="#AA0BE8FF"
                                                    Opacity="0.95"
                                                    Radius="26"
                                                    Offset="0,0" />
                                        </Label.Shadow>
                                    </Label>
                                    <Label Text="COMMAND SIGNAL VERIFIED"
                                           FontFamily="Impact"
                                           FontSize="16"
                                           CharacterSpacing="6"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#5CB9D7"
                                           Opacity="0.86" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid x:Name="StartupVsCodeScene"
                                  Opacity="0"
                                  IsVisible="False">
                                <VerticalStackLayout Spacing="16"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Border WidthRequest="176"
                                            HeightRequest="176"
                                            Stroke="#4FD4FF"
                                            StrokeThickness="1.6"
                                            StrokeShape="RoundRectangle 42"
                                            Padding="28"
                                            BackgroundColor="#180B1B2A">
                                        <Image Source="vscode_logo.svg"
                                               Aspect="AspectFit" />
                                    </Border>
                                    <Label x:Name="StartupVsCodeLabel"
                                           Text=""
                                           FontFamily="Impact"
                                           FontSize="42"
                                           CharacterSpacing="2"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#E6FBFF" />
                                    <Label Text="TACTICAL SYSTEMS FORGED IN VISUAL STUDIO CODE"
                                           FontFamily="Impact"
                                           FontSize="14"
                                           CharacterSpacing="4.5"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#6FCBE9"
                                           Opacity="0.84" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid x:Name="StartupTitleScene"
                                  Opacity="0"
                                  IsVisible="False">
                                <VerticalStackLayout Spacing="-4"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label x:Name="StartupTitleTopLabel"
                                           Text="MAUI"
                                           FontFamily="Impact"
                                           FontSize="38"
                                           CharacterSpacing="8"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#85E7FF"
                                           Opacity="0.92" />
                                    <Label x:Name="StartupTitleMainLabel"
                                           Text="Battleship"
                                           FontFamily="Impact"
                                           FontSize="84"
                                           CharacterSpacing="2"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#E9FCFF">
                                        <Label.Shadow>
                                            <Shadow Brush="#AA1AD8FF"
                                                    Opacity="1"
                                                    Radius="30"
                                                    Offset="0,0" />
                                        </Label.Shadow>
                                    </Label>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="2"
                                x:Name="StartupSkipChip"
                                HorizontalOptions="Center"
                                Padding="14,8"
                                Stroke="#5DCBFF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="#38102231">
                            <Label Text="PRESS ESC TO SKIP INTRO"
                                   FontFamily="Impact"
                                   FontSize="12"
                                   CharacterSpacing="4"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#B8F5FF" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsScrim"
                  IsVisible="{Binding IsSettingsOpen}"
                  BackgroundColor="#360b1320"
                  ZIndex="26"
                  InputTransparent="False">
                <Border x:Name="SettingsCard"
                        Style="{StaticResource GameCardBorderStyle}"
                        Margin="18"
                        MaximumWidthRequest="920"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Padding="18,16"
                        BackgroundColor="{DynamicResource GameColorSettingsCard}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Esc Command Menu"
                                       Style="{StaticResource GameSectionLabelStyle}"
                                       FontSize="24"
                                       TextColor="{DynamicResource GameColorAccent}" />
                                <Label Text="Press Esc to resume. The board stays visible behind this command console."
                                       Style="{StaticResource GameCaptionLabelStyle}"
                                       FontSize="13"
                                       TextColor="{DynamicResource GameColorTextMuted}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <Button Text="Resume"
                                        Command="{Binding ToggleSettingsPanelCommand}"
                                        Style="{StaticResource GamePrimaryButtonStyle}"
                                        HeightRequest="36"
                                        Padding="12,7" />
                                <Button Text="Quit"
                                        Clicked="OnQuitApplicationClicked"
                                        Style="{StaticResource GameSecondaryButtonStyle}"
                                        HeightRequest="36"
                                        Padding="12,7" />
                            </HorizontalStackLayout>
                        </Grid>

                        <FlexLayout Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Center">
                            <Button Text="Toggle Full Screen"
                                    Clicked="OnToggleFullScreenClicked"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7"
                                    Margin="0,0,8,8" />
                            <Button Text="New Mission"
                                    Command="{Binding NewGameCommand}"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7"
                                    Margin="0,0,8,8" />
                            <Button Text="Reset Stats"
                                    Command="{Binding ResetStatsCommand}"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7"
                                    Margin="0,0,8,8" />
                            <Button Text="Disconnect"
                                    Command="{Binding DisconnectLanCommand}"
                                    IsVisible="{Binding IsLanConnected}"
                                    Style="{StaticResource GameSecondaryButtonStyle}"
                                    HeightRequest="38"
                                    Padding="12,7"
                                    Margin="0,0,8,8" />
                        </FlexLayout>

                        <Border Style="{StaticResource GameCardBorderStyle}"
                                BackgroundColor="{DynamicResource GameColorPanel}"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <VerticalStackLayout Spacing="4"
                                                     IsVisible="{Binding ShowCpuDifficultySettings}">
                                    <Label Text="CPU Difficulty"
                                           Style="{StaticResource GameCaptionLabelStyle}" />
                                    <Picker Title="Difficulty"
                                            ItemsSource="{Binding DifficultyOptions}"
                                            TextColor="{DynamicResource GameColorTextPrimary}"
                                            TitleColor="{DynamicResource GameColorTextMuted}"
                                            BackgroundColor="{DynamicResource GameColorSurfaceAlt}"
                                            SelectedItem="{Binding SelectedDifficulty}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Animation Speed"
                                           Style="{StaticResource GameCaptionLabelStyle}" />
                                    <Picker Title="Animation Speed"
                                            ItemsSource="{Binding AnimationSpeedOptions}"
                                            TextColor="{DynamicResource GameColorTextPrimary}"
                                            TitleColor="{DynamicResource GameColorTextMuted}"
                                            BackgroundColor="{DynamicResource GameColorSurfaceAlt}"
                                            SelectedItem="{Binding SelectedAnimationSpeed}" />
                                </VerticalStackLayout>

                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="Sound FX"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding SoundEnabled}"
                                            HorizontalOptions="End" />
                                </Grid>

                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="Haptics"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding HapticsEnabled}"
                                            HorizontalOptions="End" />
                                </Grid>

                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="Background Music"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding MusicEnabled}"
                                            HorizontalOptions="End" />
                                </Grid>

                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Music Volume"
                                               Style="{StaticResource GameCaptionLabelStyle}" />
                                        <Slider Minimum="0"
                                                Maximum="1"
                                                Value="{Binding MusicVolume}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding MusicVolumePercent}"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                </Grid>

                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Sound FX Volume"
                                               Style="{StaticResource GameCaptionLabelStyle}" />
                                        <Slider Minimum="0"
                                                Maximum="1"
                                                Value="{Binding SoundFxVolume}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding SoundFxVolumePercent}"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                </Grid>

                                <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Text="Commander Voice"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding CommanderVoiceEnabled}"
                                            HorizontalOptions="End" />
                                </Grid>

                                <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="8" Grid.ColumnSpan="2">
                                    <Label Text="Turn Cinematic Overlay"
                                           Style="{StaticResource GameCaptionLabelStyle}"
                                           VerticalTextAlignment="Center" />
                                    <Switch Grid.Column="1"
                                            IsToggled="{Binding TurnCinematicsEnabled}"
                                            HorizontalOptions="End" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource GameCardBorderStyle}"
                                BackgroundColor="{DynamicResource GameColorPanel}">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="8"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Text="High contrast visuals"
                                       Style="{StaticResource GameCaptionLabelStyle}"
                                       VerticalTextAlignment="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding HighContrastMode}" />

                                <Label Grid.Row="1"
                                       Text="Large text mode"
                                       Style="{StaticResource GameCaptionLabelStyle}"
                                       VerticalTextAlignment="Center" />
                                <Switch Grid.Row="1"
                                        Grid.Column="1"
                                        IsToggled="{Binding LargeTextMode}" />

                                <Label Grid.Row="2"
                                       Text="Reduce motion effects"
                                       Style="{StaticResource GameCaptionLabelStyle}"
                                       VerticalTextAlignment="Center" />
                                <Switch Grid.Row="2"
                                        Grid.Column="1"
                                        IsToggled="{Binding ReduceMotionMode}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid x:Name="OverlayScrim"
                  IsVisible="{Binding IsOverlayVisible}"
                  BackgroundColor="#A0000000"
                  ZIndex="30"
                  InputTransparent="False">
                <Border x:Name="OverlayCard"
                        Style="{StaticResource GameCardBorderStyle}"
                        Margin="20"
                        WidthRequest="560"
                        MaximumWidthRequest="560"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Padding="18,16"
                        BackgroundColor="{DynamicResource GameColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding OverlayTitle}"
                               Style="{StaticResource GameSectionLabelStyle}"
                               FontSize="24"
                               TextColor="{DynamicResource GameColorAccent}" />

                        <Label Text="{Binding OverlaySubtitle}"
                               Style="{StaticResource GameBodyLabelStyle}"
                               LineBreakMode="WordWrap" />

                        <VerticalStackLayout x:Name="FleetRecapStack"
                                             IsVisible="{Binding ShowOverlayRecap}"
                                             BindableLayout.ItemsSource="{Binding FleetRecapItems}"
                                             Spacing="6"
                                             Margin="0,4,0,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GameCardBorderStyle}"
                                            Padding="8,6"
                                            Opacity="0">
                                        <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                                            <Image Source="{Binding ImageSource}" HeightRequest="30" Aspect="AspectFit" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource GameBodyLabelStyle}"
                                                   VerticalTextAlignment="Center" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding StatusText}"
                                                   Style="{StaticResource GameCaptionLabelStyle}"
                                                   TextColor="{Binding StatusColor}"
                                                   VerticalTextAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Border IsVisible="{Binding ShowOverlayAnalytics}"
                                Style="{StaticResource GameCardBorderStyle}"
                                BackgroundColor="{DynamicResource GameColorPanel}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Post-Game Analytics"
                                       Style="{StaticResource GameSectionLabelStyle}"
                                       FontSize="16"
                                       TextColor="{DynamicResource GameColorWarning}" />
                                <Label Text="{Binding AnalyticsAccuracyByPhase}" Style="{StaticResource GameBodyLabelStyle}" />
                                <Label Text="{Binding AnalyticsStreaks}" Style="{StaticResource GameBodyLabelStyle}" />
                                <Label Text="{Binding AnalyticsBestSequence}"
                                       Style="{StaticResource GameBodyLabelStyle}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Button Text="{Binding OverlayPrimaryActionText}"
                                Command="{Binding DismissOverlayCommand}"
                                Style="{StaticResource GamePrimaryButtonStyle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
